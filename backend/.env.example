# Azure AD / JWT
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret   # needed for MS Graph OBO flow

# Set to "true" to accept the dev mock token (NEVER in production)
AUTH_DEV_MODE=true
AUTH_DEV_SECRET=sora-dev-secret-change-me

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Cosmos DB
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-key
# Database name (defaults to "sora" if not set)
COSMOS_DATABASE_NAME=sora

# OpenAI — AI Assistant layer (mock responses if not set)
OPENAI_API_KEY=

# ClickUp — read-only integration + Product Backlog write
CLICKUP_API_KEY=
CLICKUP_LIST_ID=
# Product Backlog list — target for AI-generated user stories
CLICKUP_PRODUCT_BACKLOG_LIST_ID=
# ClickUp Docs — RAG knowledge base (v3 API)
CLICKUP_TEAM_ID=
CLICKUP_DOCS_FOLDER_ID=
