# Azure AD / JWT
AZURE_AD_TENANT_ID=your-tenant-id
AZURE_AD_CLIENT_ID=your-client-id
AZURE_AD_CLIENT_SECRET=your-client-secret   # needed for MS Graph OBO flow

# Set to "true" to accept the dev mock token (NEVER in production)
AUTH_DEV_MODE=true
AUTH_DEV_SECRET=sora-dev-secret-change-me

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Cosmos DB (future)
# COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
# COSMOS_KEY=your-key
# COSMOS_DATABASE=sora

# OpenAI (future)
# OPENAI_API_KEY=

# ClickUp (future)
# CLICKUP_API_TOKEN=
